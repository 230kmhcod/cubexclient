-- UI Функции
local function addToggle(parent, text, y, getter, setter)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.45, 0, 0, 32)
    btn.Position = UDim2.new(0.025, 0, 0, y)
    btn.BackgroundColor3 = getter() and Color3.fromRGB(0,180,0) or Color3.fromRGB(120,40,40)
    btn.Text = text .. ": " .. (getter() and "ON" or "OFF")
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.MouseButton1Click:Connect(function() 
        setter(not getter()) 
        btn.BackgroundColor3 = getter() and Color3.fromRGB(0,180,0) or Color3.fromRGB(120,40,40) 
        btn.Text = text .. ": " .. (getter() and "ON" or "OFF") 
        saveSettings() 
        if text == "China Hat" then updateAllHats() end
        if text == "Target ESP" then updateTargetESP() end
        if text == "Particles" then updateParticles() end
    end)
    return btn
end

local function addSlider(parent, text, y, minVal, maxVal, getter, setter)
    local frame = Instance.new("Frame", parent)
    frame.Size = UDim2.new(0.45, 0, 0, 48)
    frame.Position = UDim2.new(0.025, 0, 0, y)
    frame.BackgroundTransparency = 1
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 18)
    label.Text = text .. ": " .. tostring(getter())
    label.TextColor3 = Color3.fromRGB(200,200,200)
    local slider = Instance.new("TextButton", frame)
    slider.Size = UDim2.new(1, 0, 0, 24)
    slider.Position = UDim2.new(0, 0, 0, 22)
    slider.BackgroundColor3 = Color3.fromRGB(55,55,75)
    local fill = Instance.new("Frame", slider)
    fill.Size = UDim2.new((getter() - minVal)/(maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0,150,255)
    local dragging = false
    slider.MouseButton1Down:Connect(function()
        dragging = true
        while dragging do
            local relX = math.clamp(UserInputService:GetMouseLocation().X - slider.AbsolutePosition.X, 0, slider.AbsoluteSize.X)
            local newVal = minVal + (relX / slider.AbsoluteSize.X) * (maxVal - minVal)
            setter(math.round(newVal * 10) / 10)
            fill.Size = UDim2.new((getter() - minVal)/(maxVal - minVal), 0, 1, 0)
            label.Text = text .. ": " .. tostring(getter())
            saveSettings()
            if text == "Hat Size" then updateAllHats() end
            task.wait()
        end
    end)
    UserInputService.InputEnded:Connect(function(input) 
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            dragging = false 
        end 
    end)
    return frame
end

