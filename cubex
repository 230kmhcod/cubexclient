-- ========== СОХРАНЕНИЕ ==========
local function saveSettings()
    pcall(function() 
        writefile("CubeX_Client_v20.json", game:GetService("HttpService"):JSONEncode(Settings)) 
    end) 
end

local function loadSettings()
    pcall(function() 
        if isfile("CubeX_Client_v20.json") then
            local loaded = game:GetService("HttpService"):JSONDecode(readfile("CubeX_Client_v20.json"))
            for k,v in pairs(loaded) do 
                if Settings[k] then 
                    for k2,v2 in pairs(v) do 
                        if Settings[k][k2] ~= nil then 
                            Settings[k][k2] = v2 
                        end 
                    end 
                end 
            end
        end
    end)
end
