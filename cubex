-- ========== ASPECT RATIO ==========
local cameraViewport = nil
local function applyAspectRatio()
    if cameraViewport then cameraViewport:Destroy() cameraViewport = nil end
    if not Settings.AspectRatio.Enabled then return end
    
    local ratio = 1
    local mode = Settings.AspectRatio.Mode
    if mode == "4:3" then ratio = 4/3
    elseif mode == "16:9" then ratio = 16/9
    elseif mode == "21:9" then ratio = 21/9
    elseif mode == "1:1" then ratio = 1 end
    
    local screenWidth = workspace.CurrentCamera.ViewportSize.X
    local screenHeight = workspace.CurrentCamera.ViewportSize.Y
    local currentRatio = screenWidth / screenHeight
    
    cameraViewport = Instance.new("ViewportFrame")
    cameraViewport.BackgroundTransparency = 1
    cameraViewport.Parent = game:GetService("CoreGui")
    
    local cameraClone = Instance.new("Camera")
    cameraClone.CFrame = Camera.CFrame
    cameraClone.FieldOfView = Camera.FieldOfView
    cameraViewport.CurrentCamera = cameraClone
    
    if currentRatio > ratio then
        local newWidth = screenHeight * ratio
        cameraViewport.Size = UDim2.new(0, newWidth, 1, 0)
        cameraViewport.Position = UDim2.new(0.5, -newWidth/2, 0, 0)
    else
        local newHeight = screenWidth / ratio
        cameraViewport.Size = UDim2.new(1, 0, 0, newHeight)
        cameraViewport.Position = UDim2.new(0, 0, 0.5, -newHeight/2)
    end
end

