local function addKeybind(parent, text, y, getter, setter)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.45, 0, 0, 32)
    btn.Position = UDim2.new(0.025, 0, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(60,60,85)
    btn.Text = text .. ": " .. (getter() == "None" and "Не задана" or getter())
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    local listening = false
    local conn
    btn.MouseButton1Click:Connect(function()
        if listening then return end
        listening = true
        btn.Text = text .. ": ..."
        conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                local key = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
                setter(key)
                btn.Text = text .. ": " .. key
                listening = false
                conn:Disconnect()
                saveSettings()
            end
        end)
        task.wait(4)
        if listening then
            listening = false
            btn.Text = text .. ": " .. (getter() == "None" and "Не задана" or getter())
            if conn then conn:Disconnect() end
        end
    end)
    return btn
end

